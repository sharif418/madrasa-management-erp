# ============================================================
# Madrasa Manager — Environment Configuration
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/madrasa_manager?schema=public"

# Session Secret (CHANGE IN PRODUCTION!)
MM_SECRET="madrasa-manager-production-secret-change-this-to-a-random-64-char-string"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ============================================================
# Integration credentials are managed via Admin Dashboard
# (Settings → Integrations). No need to set them here.
# The app stores them encrypted in the database.
# ============================================================
